# Normalize line endings — all text files stored as LF, checked out as LF on all platforms
* text=auto eol=lf

# Explicitly keep these as LF even on Windows
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env  text eol=lf

# Binaries — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
